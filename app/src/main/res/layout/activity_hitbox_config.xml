<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hitbox_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox1"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_margin="20dp" />

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="20dp" />

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="260dp"
        android:layout_marginTop="20dp" />

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox4"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="140dp" />

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox5"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="140dp" />

    <com.quyetgd.keyvieweroverlay.HitboxView
        android:id="@+id/hitbox6"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="260dp"
        android:layout_marginTop="140dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="50dp"
        android:text="Kéo thả vùng giữa để di chuyển, kéo 4 góc để thay đổi kích thước"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnResetHitbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Đặt lại mặc định" />

        <Button
            android:id="@+id/btnSaveHitbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lưu" />
    </LinearLayout>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="BẢNG ĐIỀU KHIỂN"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/btnCheck"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.499"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Kiểm tra Shizuku"
        app:layout_constraintBottom_toTopOf="@+id/tvShizukuStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvStatus" />

    <TextView
        android:id="@+id/tvShizukuStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trạng thái: Đang kiểm tra..."
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/switchOverlay"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnCheck" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Bật/Tắt Overlay"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/btnConfigHitbox"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvShizukuStatus" />

    <Button
        android:id="@+id/btnConfigHitbox"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Cài đặt Hitbox"
        app:layout_constraintBottom_toTopOf="@+id/btnConfigKeyViewer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/switchOverlay" />

    <Button
        android:id="@+id/btnConfigKeyViewer"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cài đặt Key Viewer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnConfigHitbox" />

    <LinearLayout
        android:id="@+id/layoutAccessibilityPrompt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="YÊU CẦU QUYỀN TRỢ NĂNG"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Tại sao Key Viewer cần quyền này?\n\nHệ thống (đặc biệt là Game Turbo) thường tự động khóa cảm ứng xuyên thấu khi phát hiện lớp phủ toàn màn hình đè lên game.\n\nĐể vẽ các 'Điểm chạm' mượt mà thời gian thực và cho phép bạn nhấn xuyên thấu không bị trễ, ứng dụng cần dùng đặc quyền hiển thị của Trợ Năng (Accessibility).\n\n🔒 CAM KẾT BẢO MẬT:\nỨng dụng không đọc nội dung màn hình, không thu thập dữ liệu cá nhân. Quyền này chỉ dùng duy nhất để vẽ đồ họa điểm chạm."
            android:textColor="#333333"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnAgreeAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="CẤP QUYỀN NGAY" />

        <Button
            android:id="@+id/btnCancelAccessibility"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QUAY LẠI"
            android:textColor="#777777" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvXiaomiTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/xiaomi_warning_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvXiaomiMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/xiaomi_warning_msg"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnXiaomiSettings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/xiaomi_warning_settings"
                android:textColor="#BB86FC"
                app:rippleColor="#33BB86FC" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnXiaomiCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/xiaomi_warning_cancel"
                android:textColor="#80FFFFFF"
                app:rippleColor="#33FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnXiaomiDone"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/xiaomi_warning_continue"
                android:textColor="#BB86FC"
                app:rippleColor="#33BB86FC" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <!-- Thành phần 1 (Phía trên): Vùng bay (RainKey) -->
    <com.quyetgd.keyvieweroverlay.KeyTrailView
        android:id="@+id/keyTrailView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#40FFFFFF" />

    <!-- Thành phần 2 (Phía dưới): 6 Phím bấm -->
    <LinearLayout
        android:id="@+id/keysContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/key1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="2"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key3"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="3"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key4"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="4"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key5"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="5"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key6"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="6"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Phần đáy: Bộ đếm KPS và Total - Rộng theo khung cha -->
    <LinearLayout
        android:id="@+id/bottomCountersContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:clipChildren="false">

        <RelativeLayout
            android:id="@+id/kpsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">
            <TextView
                android:id="@+id/tvKpsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="KPS" />
            <TextView
                android:id="@+id/tvKpsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="0" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/totalContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">
            <TextView
                android:id="@+id/tvTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Total" />
            <TextView
                android:id="@+id/tvTotalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="0" />
        </RelativeLayout>
    </LinearLayout>

</LinearLayout>

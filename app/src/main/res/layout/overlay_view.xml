<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <!-- Thành phần 1 (Phía trên): Vùng bay (RainKey) -->
    <com.quyetgd.keyvieweroverlay.KeyTrailView
        android:id="@+id/keyTrailView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#40FFFFFF" />

    <!-- Thành phần 2 (Phía dưới): 6 Phím bấm -->
    <LinearLayout
        android:id="@+id/keysContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/key1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="2"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key3"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="3"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key4"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="4"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key5"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="5"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key6"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:text="6"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Phần đáy: Bộ đếm KPS và Total - Rộng theo khung cha -->
    <LinearLayout
        android:id="@+id/bottomCountersContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvKps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:padding="4dp"
            android:text="KPS\n0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_key_normal"
            android:gravity="center"
            android:padding="4dp"
            android:text="Total\n0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KeyViewerOverlay" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="android:windowBackground">@color/md3_background</item>
        <item name="colorPrimary">@color/md3_primary</item>
        <item name="colorSurface">@color/md3_surface</item>
        <item name="android:statusBarColor">@color/md3_background</item>
        <item name="android:navigationBarColor">@color/md3_background</item>
        <item name="materialAlertDialogTheme">@style/CustomMaterialAlertDialog</item>
    </style>

    <style name="Theme.KeyViewerOverlay" parent="Base.Theme.KeyViewerOverlay" />

    <style name="CompactNeonButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/md3_primary_neon_bg</item>
        <item name="android:textColor">@color/md3_primary</item>
        <item name="rippleColor">@color/md3_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="CustomMaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearance">@style/DialogShapeAppearance</item>
    </style>

    <style name="DialogShapeAppearance" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="NeonButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/md3_primary_neon_bg</item>
        <item name="android:textColor">@color/md3_primary</item>
        <item name="rippleColor">@color/md3_primary</item>
    </style>

    <style name="RoundedBottomSheetDialog" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/RoundedBottomSheetStyle</item>
    </style>

    <style name="RoundedBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/RoundedShapeAppearance</item>
        <item name="backgroundTint">@color/md3_surface</item>
    </style>

    <style name="RoundedShapeAppearance" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>